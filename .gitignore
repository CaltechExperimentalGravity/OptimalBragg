##---------------------------------------------------
## Remove autosaves generated by the Matlab editor
## We have git for backups!
##---------------------------------------------------

# Windows default autosave extension
*.asv

# OSX / *nix default autosave extension
*.m~

# Compiled MEX binaries (all platforms)
*.mex*

# Simulink Code Generation
slprj/

# Session info
octave-workspace

# Files from OpenFilter used to check coatings
*.ofp

# Data files
**/*.mat

# Excel spreadsheet coating layer thickness files
**/*.xlsx

#hdf5
**/*.hdf5

#pyc
**/*.pyc

# Sphinx build output
docs/_build/

# Auto-generated run reports (regenerated from HDF5 data)
docs/runs/ETM/*.rst
docs/runs/ITM/*.rst
!docs/runs/index.rst

# Generated figures
**/Figures/ETM/
**/Figures/ITM/

# Python cache
__pycache__/
*.egg-info/
